# ─────────────── Resend (envio) ───────────────
# As credenciais do Resend agora são por-cliente, configuradas na UI em /clients
# (cada SaaS pode ter sua própria API key + FROM_EMAIL). Se preferir, ainda
# pode definir os valores abaixo como fallback global — eles são usados quando
# o cliente não tiver credencial preenchida.
RESEND_API_KEY=
FROM_EMAIL=
REPLY_TO=

# ─────────────── Groq (IA pra personalizar abertura) ───────────────
GROQ_API_KEY=gsk_xxx

# ─────────────── Web UI (python app.py) ───────────────
UI_PASSWORD="troque-essa-senha"
SESSION_SECRET="qualquer-string-aleatoria-longa-pra-assinar-cookies"
PORT=3000

# URL pública usada nos links de unsubscribe dos emails (sem barra no fim).
# Em dev pode deixar em branco que ele usa http://localhost:$PORT.
BASE_URL="https://outreach.seu-dominio.com"

# ─────────────── Webhook Resend ───────────────
# Segredo do webhook do Resend (Dashboard > Webhooks). Se vazio, o endpoint
# /webhooks/resend aceita sem validar assinatura (ok só em dev).
RESEND_WEBHOOK_SECRET=

# ─────────────── Scraper ───────────────
# Default = headless. Coloque SCRAPER_HEADFUL=1 em dev pra ver o Chromium rodando.
SCRAPER_HEADFUL=
