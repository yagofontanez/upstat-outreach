<%- include('_header', { title: 'review · upstat outreach', active: 'review' }) %>
<header class="page-head">
  <span class="eyebrow">02 ▸ triage</span>
  <h1>review the queue.</h1>
  <p>approve leads with a verified email, drop the rest. edits save on blur. <span class="mono" style="color:var(--text-dim);">y</span> approves the focused row, <span class="mono" style="color:var(--text-dim);">n</span> drops it.</p>
</header>

<% if (leads.length === 0) { %>
  <div class="empty">
    <pre class="ascii">           ┌───────────────┐
           │   //  empty   │
           └───────────────┘</pre>
    <h3>nothing pending.</h3>
    <p>run a <a href="/scrape" class="mono">/scrape</a> to populate the queue.</p>
  </div>
<% } else { %>
  <div class="bulk-bar">
    <span class="count"><strong><%= leads.length %></strong> pending</span>
    <span class="spacer"></span>
    <button type="button" class="btn btn-sm btn-ghost" data-bulk="approve-with-email">approve all w/ email</button>
    <button type="button" class="btn btn-sm btn-ghost" data-bulk="reject-no-email">drop all w/o email</button>
    <button type="button" class="btn btn-sm btn-danger" data-bulk="reject-selected">drop selected</button>
    <button type="button" class="btn btn-sm btn-primary" data-bulk="approve-selected">approve selected</button>
  </div>

  <table class="leads-table">
    <thead>
      <tr>
        <th style="width:34px;"><input type="checkbox" id="check-all"></th>
        <th>company</th>
        <th>email</th>
        <th>site</th>
        <th>source</th>
        <th class="actions-col">
          actions
          <span class="kbd">y</span><span class="kbd">n</span>
        </th>
      </tr>
    </thead>
    <tbody>
      <% leads.forEach(lead => { const key = lead.website || lead.name; const hasPers = !!lead.personalizedHook; %>
        <tr data-key="<%= key %>">
          <td><input type="checkbox" class="row-check"></td>
          <td>
            <a class="name lead-detail-link" href="/leads/<%= encodeURIComponent(key) %>"><%= lead.name %></a>
            <% if (lead.phone) { %><div class="meta"><%= lead.phone %></div><% } %>
            <div class="meta pers-status <%= hasPers ? 'ok' : 'missing' %>">
              <%= hasPers ? '✓ personalized' : '○ not personalized' %>
            </div>
          </td>
          <td>
            <input class="email-input" type="email" value="<%= lead.email || '' %>" placeholder="(empty)">
          </td>
          <td>
            <% if (lead.website) { %>
              <a class="site-link" href="<%= lead.website %>" target="_blank" rel="noopener"><%= lead.website.replace(/^https?:\/\//, '') %></a>
            <% } else { %>
              <span class="faint mono" style="font-size:11px;">—</span>
            <% } %>
          </td>
          <td><span class="meta" style="margin: 0;"><%= lead.searchedAs || '—' %></span></td>
          <td class="actions-col">
            <div class="row-actions">
              <button type="button" data-action="preview" title="preview email">P</button>
              <button type="button" data-action="approve" title="approve (Y)">Y</button>
              <button type="button" data-action="reject" title="drop (N)">N</button>
            </div>
          </td>
        </tr>
        <tr class="pers-row" data-key="<%= key %>">
          <td></td>
          <td colspan="5">
            <div class="pers-fields">
              <label class="pers-label">subject</label>
              <input class="pers-subject" type="text" value="<%= buildSubject(lead.name) %>" readonly title="subject used on send">
              <label class="pers-label">hook</label>
              <textarea class="pers-hook" rows="2" maxlength="300" placeholder="(no personalized opening — falls back to default)"><%= lead.personalizedHook || '' %></textarea>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div id="email-preview-modal" class="modal hidden" aria-hidden="true">
    <div class="modal-backdrop" data-modal-close></div>
    <section class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="email-preview-title">
      <div class="modal-head">
        <div>
          <span class="eyebrow">preview</span>
          <h2 id="email-preview-title">email render</h2>
        </div>
        <button type="button" class="modal-close" data-modal-close title="close">×</button>
      </div>
      <div class="email-preview-meta">
        <span class="k">subject</span>
        <strong id="lead-preview-subject">—</strong>
      </div>
      <div class="email-preview-tabs">
        <button type="button" class="active" data-lead-preview-tab="html">html</button>
        <button type="button" data-lead-preview-tab="text">text</button>
      </div>
      <div id="lead-preview-html" class="email-preview-html"></div>
      <pre id="lead-preview-text" class="email-preview-text hidden"></pre>
    </section>
  </div>
<% } %>
<%- include('_footer') %>
