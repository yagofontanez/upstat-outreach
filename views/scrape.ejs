<%- include('_header', { title: 'scrape · upstat outreach', active: 'scrape' }) %>

<header class="page-head">
  <span class="eyebrow">01 ▸ collect</span>
  <h1>scrape the map.</h1>
  <p>opens chromium (visible) and walks the result list. takes a few minutes per batch. results merge into <span class="mono">leads.json</span> by website — duplicates dedupe automatically.</p>
</header>

<div class="split">
  <form id="scrape-form" class="panel">
    <div class="panel-head">▸ parameters</div>
    <div class="form-grid">
      <div class="field">
        <label>search term</label>
        <input name="term" placeholder="agência de marketing" required>
      </div>
      <div class="field">
        <label>city</label>
        <input name="city" placeholder="Curitiba" required>
      </div>
      <div class="field">
        <label>max results</label>
        <input name="max" type="number" min="1" max="100" value="30">
        <span class="hint">1–100. defaults to 30.</span>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top: 4px; justify-content: center;">run scrape</button>
    </div>
  </form>

  <div id="progress" class="terminal hidden">
    <div class="terminal-head">
      <span class="dot live"></span>
      <span>scrape · live</span>
      <span style="margin-left:auto;" id="scrape-meta"></span>
    </div>
    <div class="terminal-body" id="scrape-log"></div>
    <div id="scrape-summary" class="summary" style="padding: 0 var(--s-4) var(--s-4);"></div>
  </div>
</div>
<%- include('_footer') %>
